```gitignore
# =========================
# Python / FastAPI
# =========================
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
ENV/

# Environment Variables
.env
.env.*

# Python Packaging
build/
dist/
*.egg-info/
.eggs/

# Logs
*.log

# Test & Coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# IDE
.vscode/
.idea/

# OS Files
.DS_Store
Thumbs.db

# =========================
# React / Node
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build
build/
dist/

# Vite
.vite/

# Cache
.cache/

# =========================
# Images & Uploads (Optional)
# Uncomment if uploads are generated
# =========================
# uploads/
# temp/
# *.jpg
# *.jpeg
# *.png

# =========================
# MongoDB
# =========================
*.db
*.sqlite
*.sqlite3

# =========================
# Misc
# =========================
coverage/
```
